              "masked": false,
              "fontSize": 14,
              "fontWeight": "bold"
            },
            {
              "type": "text",
              "content": "But this specific text is masked",
              "masked": true,
              "fontSize": 12,
              "color": "#D32F2F"
            }
          ]
        }
      ]
    },
