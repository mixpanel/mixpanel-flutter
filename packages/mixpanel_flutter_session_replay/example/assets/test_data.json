          "type": "text",
          "content": "Masked PII: SSN 123-45-6789, Phone: (555) 123-4567",
          "masked": true,
          "fontSize": 16,
          "fontWeight": "bold",
          "color": "#D32F2F"
        },
        {
          "type": "text",
          "content": "Email: user@example.com (should be masked)",
          "masked": true,
          "fontSize": 14,
