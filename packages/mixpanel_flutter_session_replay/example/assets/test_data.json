          "color": "#F57C00"
        },
        {
          "type": "text",
          "content": "Public product information - Model XYZ-2024",
          "masked": false,
          "fontSize": 18,
          "fontWeight": "bold",
          "color": "#388E3C"
        }
      ]
    },
    {
