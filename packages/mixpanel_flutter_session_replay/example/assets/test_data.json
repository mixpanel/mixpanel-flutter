      "title": "Text Content Variations",
      "description": "Testing text masking behavior with different content types",
      "items": [
        {
          "type": "text",
          "content": "This is normal unmasked text - publicly visible information",
          "masked": false,
          "fontSize": 16,
          "fontWeight": "normal"
